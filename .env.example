# Odoo connection settings
ODOO_URL=http://localhost:8069
ODOO_DB=your_odoo_database
ODOO_USER=your_odoo_username
ODOO_PASSWORD=your_odoo_password

# AI integrations
ANTHROPIC_API_KEY=your_anthropic_api_key

# Bitbucket credentials for review cloning
BITBUCKET_USER=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password

# Scheduler time settings
CRON_SYNC_TIME=07:45
CRON_PRIORITISE_TIME=09:00
CRON_REVIEW_TIME=07:00

# Duplicate title detection threshold (0-100)
DUPLICATE_THRESHOLD=85
